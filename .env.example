# ─────────────────────────────────────────────────────────────────────────────
# Karma Timal — Environment variables template
#
# 1. Copy this file to `.env.local` (never commit).
# 2. Fill in the values you actually use.
# 3. On Vercel, add the same keys via Project Settings → Environment Variables,
#    scoped to "Production" (and "Preview" if you want).
#
# Anything prefixed with NEXT_PUBLIC_ is bundled into the client JS — NEVER
# put a secret there.
# ─────────────────────────────────────────────────────────────────────────────

# --- Site identity (public, OK to expose) ----------------------------------
NEXT_PUBLIC_SITE_URL="https://karmatimal.com"

# --- Booking form delivery (SECRET — server-only) --------------------------
# Resend.com API key, used by app/booking/actions.ts to deliver emails.
# Create one at https://resend.com → Project → API Keys (use a key restricted
# to "Send only" permission).
RESEND_API_KEY=""

# Recipient — where booking requests arrive.
BOOKING_RECIPIENT_EMAIL="booking@karmatimal.com"

# Verified sender (must be a domain you control + DKIM verified in Resend).
BOOKING_FROM_EMAIL="noreply@karmatimal.com"

# --- (Optional) Upstash Redis for distributed rate limiting ---------------
# When set, replace the in-memory rate-limit in middleware.ts with a Redis-backed
# limiter. Highly recommended in production.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --- (Optional) Sentry / error monitoring ---------------------------------
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
